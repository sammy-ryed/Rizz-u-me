# Groq API
GROQ_API_KEY=your_groq_api_key_here

# Adzuna Job API - Get from https://developer.adzuna.com/
ADZUNA_API_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# JSearch API (RapidAPI)
JSEARCH_RAPIDAPI_KEY=your_rapidapi_key_here
# Optional override (default used in code: jsearch.p.rapidapi.com)
JSEARCH_RAPIDAPI_HOST=jsearch.p.rapidapi.com
